# FastAPI service configuration
ENV=development
API_PREFIX=/api/v1

# Security
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql://username:password@host:5432/database

# Frontend / CORS
CORS_ORIGINS=["http://localhost:3000","https://rakuraku-energy.archi-prisma.co.jp"]

# Feature defaults
DEFAULT_TARIFF_PER_KWH=25.0

# Billing / Stripe
# Test mode IDs are in PRICING_STATUS.md. Use live-mode IDs for production.
APP_PUBLIC_URL=https://rakuraku-energy.archi-prisma.co.jp
STRIPE_SECRET_KEY=                          # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=                      # whsec_... from stripe listen or Dashboard
STRIPE_PRICE_ID_ENERGY=                     # price_... for energy_monthly (JPY 9,800/month recurring)
STRIPE_PRICE_ID_CIRCLE=                     # price_... for circle membership detection
STRIPE_PRICE_ID_PROJECT_PASS=               # price_... for project_pass (JPY 4,980 one_time)
STRIPE_PROJECT_PASS_DAYS=30
BILLING_BYPASS=false
