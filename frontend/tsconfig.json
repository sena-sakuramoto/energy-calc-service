{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/residential/**/*.ts",
    "src/residential/**/*.tsx",
    "src/residential/**/*.js",
    "src/residential/**/*.jsx"
  ],
  "exclude": ["node_modules"]
}
